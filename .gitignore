node_modules/

# Environment — contains secrets
.env

# Personal API configs — commit only defaults (e.g. weather.json)
config/apis/*.json
!config/apis/weather.json

# SQLite database
data/

# Trained docs (auto-generated by npm run train)
docs/*/

# Ignore all markdown files in docs root, except Llooma-prefixed ones
docs/*.md
!docs/Llooma*.md

# Keep the docs folder itself
!docs/.gitkeep
